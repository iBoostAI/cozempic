# Maintainer: Ruya <j@junaidq.com>
pkgname=cozempic
pkgver=1.8.14
pkgrel=1
pkgdesc="Context cleaning CLI for Claude Code — prune bloat, protect agent teams from compaction"
arch=('any')
url="https://github.com/Ruya-AI/cozempic"
license=('MIT')
depends=('python>=3.10')
makedepends=('python-build' 'python-installer' 'python-setuptools' 'python-wheel')
source=("https://files.pythonhosted.org/packages/source/c/cozempic/cozempic-${pkgver}.tar.gz")
sha256sums=('9c983afaccc379f505a4c0d7012501b5a5a10f92c0f9d785cead0583600d3dfe')

build() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  python -m build --wheel --no-isolation
}

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  python -m installer --destdir="${pkgdir}" dist/*.whl
}
